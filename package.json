    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/octicon": "^1.2.23",
    "@iconify-json/tabler": "^1.2.33",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260429.1",
    "@vercel/config": "^0.2.1",
    "babel-plugin-react-compiler": "1.0.0",
    "cspell": "^10.0.0",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "globals": "^17.5.0",
    "lint-staged": "^16.4.0",
    "shiki": "^4.0.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm type-check && pnpm lint-staged --config lint-staged.config.ts"
  }
}
